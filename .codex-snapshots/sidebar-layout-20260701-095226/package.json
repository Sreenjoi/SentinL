{
  "name": "sentinl-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.cjs",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "check:root": "node scripts/assertProjectRoot.cjs",
    "build": "node scripts/assertProjectRoot.cjs && node scripts/checkViteEnv.cjs && vite build && node scripts/buildServer.cjs",
    "build:production": "node scripts/assertProjectRoot.cjs && node scripts/checkViteEnv.cjs && vite build && node scripts/buildServer.cjs",
    "build:applet": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:integration:live": "vitest run --project=live",
    "test:smoke": "vitest run --project=smoke --testTimeout=15000",
    "test:load": "cross-env TEST_SCENARIO=100_per_min vitest run --project=load --testTimeout=15000",
    "test:stress": "cross-env TEST_SCENARIO=5000_per_min vitest run --project=load --testTimeout=15000",
    "test:spike": "cross-env TEST_SCENARIO=spike_500 vitest run --project=load --testTimeout=15000",
    "test:soak": "cross-env TEST_SCENARIO=soak vitest run --project=load --testTimeout=15000"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.20",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "discord-api-types": "^0.38.46",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.477.0",
    "motion": "^12.0.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tweetnacl": "^1.0.3",
    "typescript": "~5.8.2",
    "undici": "^8.5.0",
    "uuid": "^11.1.1",
    "vite": "^6.2.0"
  },
  "overrides": {
    "@discordjs/rest": {
      "undici": "^6.27.0"
    },
    "discord.js": {
      "undici": "^6.27.0"
    },
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@firebase/eslint-plugin-security-rules": "^0.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}