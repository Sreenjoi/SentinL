# --- STRICT PRODUCTION VARIABLES ---
# DEPLOYMENT CHECKLIST: In a real production deployment outside of AI Studio (e.g. Railway, Vercel, Render),
# ALL of these must be present, and they MUST NOT be placeholder ("YOUR_VALUE_HERE") values.
# 
# Production builds require these frontend variables:
# - VITE_FIREBASE_API_KEY
# - VITE_FIREBASE_AUTH_DOMAIN
# - VITE_FIREBASE_PROJECT_ID
# - VITE_FIREBASE_APP_ID
# - VITE_FIRESTORE_DATABASE_ID
# - VITE_DISCORD_CLIENT_ID

# APP_URL: The URL where this applet is hosted.
# MUST be https:// in production.
APP_URL="https://sentinl.xyz"

# AI PROVIDER CONFIGURATION
PRIMARY_AI_PROVIDER="cloudflare"

# CLOUDFLARE AI
CLOUDFLARE_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"
CLOUDFLARE_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"
CLOUDFLARE_FAST_MODEL="@cf/qwen/qwen3-30b-a3b-fp8"

# GROQ API (optional fallback / premium escalation)
GROQ_API_KEY="YOUR_GROQ_API_KEY"
PRIMARY_AI_MODEL="llama-3.1-8b-instant"
PREMIUM_AI_MODEL="llama-3.3-70b-versatile"

# DISCORD CREDENTIALS
# VITE_DISCORD_CLIENT_ID must match DISCORD_CLIENT_ID
VITE_DISCORD_CLIENT_ID="YOUR_VALUE_HERE"
DISCORD_CLIENT_ID="YOUR_VALUE_HERE"
DISCORD_CLIENT_SECRET="YOUR_VALUE_HERE"
DISCORD_BOT_TOKEN="YOUR_VALUE_HERE"
DISCORD_PUBLIC_KEY="YOUR_VALUE_HERE"
# Set this to "false" for dashboard/API-only replicas. Exactly one deployed instance should run the Discord Gateway bot.
DISCORD_BOT_ENABLED="true"

# FIREBASE ADMIN (Backend)
FIREBASE_SERVICE_ACCOUNT='{"project_id": "real-project", "private_key": "..."}'
# Alternately set individual FIREBASE_PROJECT_ID, FIREBASE_CLIENT_EMAIL, FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID="YOUR_VALUE_HERE"
FIREBASE_CLIENT_EMAIL="YOUR_VALUE_HERE"
FIREBASE_PRIVATE_KEY="YOUR_VALUE_HERE"
FIRESTORE_DATABASE_ID="YOUR_VALUE_HERE"
ALLOW_DEFAULT_FIRESTORE_DATABASE="false"

# FIREBASE CLIENT (Frontend via Vite)
# These cannot use fallback "ai-studio" projects in external production.
VITE_FIREBASE_API_KEY="YOUR_VALUE_HERE"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_VALUE_HERE"
VITE_FIREBASE_PROJECT_ID="YOUR_VALUE_HERE"
VITE_FIREBASE_APP_ID="YOUR_VALUE_HERE"
VITE_FIRESTORE_DATABASE_ID="YOUR_VALUE_HERE"

# PAYMENTS
# Set to "true" to require Razorpay configuration at startup
PAYMENTS_ENABLED="false"
RAZORPAY_KEY_ID="YOUR_VALUE_HERE"
RAZORPAY_KEY_SECRET="YOUR_VALUE_HERE"
RAZORPAY_WEBHOOK_SECRET="YOUR_VALUE_HERE"

# --- DEVELOPMENT / PREVIEW ONLY ---
# ALLOW_AI_STUDIO_EMBED: By default, AI Studio framing is blocked in production.
# Set to "true" only when running inside AI Studio preview/share environments to explicitly allow embedding.
ALLOW_AI_STUDIO_EMBED="false"

# AI_STUDIO_PREVIEW: Optional, used to skip strict Vite frontend env checks during preview builds where they aren't provided
AI_STUDIO_PREVIEW="false"

# Social Integrations
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=
X_API_BEARER_TOKEN=

# Set to "true" to enable the automated recommendations job (consumes AI provider tokens)
ENABLE_RECOMMENDATIONS_JOB="false"

# Groq Rate Limiter Settings
GROQ_RPM_LIMIT=25
GROQ_TPM_LIMIT=4500
GROQ_TOKEN_SAFETY_RATIO=0.8
GROQ_GLOBAL_LIMITER_ENABLED=true

# ADMIN EMAIL
ADMIN_EMAIL=
